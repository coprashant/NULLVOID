{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Desktop",
      "type": "shell",
      "command": ".\\gradlew.bat :desktop:run",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$java"
    },
    {
      "label": "Build Web (TeaVM -> game.js)",
      "type": "shell",
      "command": ".\\gradlew.bat :html:generateJs",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$java"
    },
    {
      "label": "Package Desktop JAR",
      "type": "shell",
      "command": ".\\gradlew.bat :desktop:jar",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$java"
    },
    {
      "label": "Serve Game Locally (port 8080)",
      "type": "shell",
      "command": "python -m http.server 8080",
      "options": {
        "cwd": "${workspaceFolder}/html/webapp"
      },
      "group": "test",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": ".\\gradlew.bat clean",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
